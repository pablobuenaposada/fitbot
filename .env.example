# FitBot Configuration
# Copy to .env and fill in your values

# Your gym's subdomain from the URL (e.g., "lahuellacrossfit" from https://lahuellacrossfit.aimharder.com)
box-name=your-gym-subdomain

# Your gym's box ID (find via browser DevTools Network tab when booking a class)
box-id=12345

# Days in advance to book (depends on your gym's booking window, usually 1-3)
days-in-advance=2

# Booking schedule - JSON with day of week (0=Monday, 6=Sunday) mapped to class time and name
# Time format: HHMM (24-hour). Name: partial match against class title.
#
# Example: Book "CrossFit" at 18:15 on Monday and Wednesday only:
# booking-goals={"0":{"time":"1815","name":"CrossFit"},"2":{"time":"1815","name":"CrossFit"}}
#
# Example: Book the SAME class EVERY day (Monday-Sunday):
# booking-goals={"0":{"time":"1815","name":"CrossFit"},"1":{"time":"1815","name":"CrossFit"},"2":{"time":"1815","name":"CrossFit"},"3":{"time":"1815","name":"CrossFit"},"4":{"time":"1815","name":"CrossFit"},"5":{"time":"1000","name":"CrossFit"},"6":{"time":"1000","name":"CrossFit"}}
#
booking-goals={"0":{"time":"1815","name":"CrossFit"}}

# Optional: SOCKS5 proxy if you're geo-blocked (format: socks5://ip:port)
proxy=

# Optional: Family member ID for multi-user accounts (find via browser DevTools)
family-id=
