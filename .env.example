# FitBot Configuration
# Copy to .env and fill in your values

# Your gym's subdomain (e.g., "lahuellacrossfit" from https://lahuellacrossfit.aimharder.com)
box-name=yourgym

# Your gym's box ID (find via browser DevTools Network tab when booking)
box-id=1234

# Days in advance to book (depends on your gym's booking window, usually 1-3)
days-in-advance=1

# Booking schedule - JSON with day of week (0=Monday, 6=Sunday) mapped to time and class name
# Time format: HHMM (24-hour). Name: partial match against class title.
#
# Example: Book "CrossFit" at 18:15 on Monday and Wednesday:
# booking-goals={"0":{"time":"1815","name":"CrossFit"},"2":{"time":"1815","name":"CrossFit"}}
#
# Example: Same class EVERY weekday at 19:00:
booking-goals={"0":{"time":"1900","name":"WOD"},"1":{"time":"1900","name":"WOD"},"2":{"time":"1900","name":"WOD"},"3":{"time":"1900","name":"WOD"},"4":{"time":"1900","name":"WOD"}}

# Optional: SOCKS5 proxy if geo-blocked (format: socks5://ip:port)
proxy=

# Optional: Family member ID for multi-user accounts (find via browser DevTools)
family-id=
